# DrawSpec environment variables
# Copy this file to .env and fill in your values
# mise.toml automatically loads .env via _.file = ".env"

# GitHub Personal Access Token — required for GitHub MCP server
# Used by opencode.json to authenticate with GitHub API
# Create at: https://github.com/settings/tokens
# Required scopes: repo, read:org, project
GITHUB_PERSONAL_ACCESS_TOKEN=
