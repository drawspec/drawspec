{
  "name": "drawspec",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "extensions/*"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "lefthook install",
    "check": "biome check . && bun run typecheck && bun run test",
    "format": "biome check --write .",
    "lint": "biome lint .",
    "typecheck": "tsc -b",
    "test": "bun test --path-ignore-patterns '**/__bench__/**'",
    "test:watch": "bun test --watch",
    "bench": "DRAWSPEC_RUN_BENCH=1 bun test --bench packages/core/src/__bench__ packages/layout/src/__bench__",
    "build": "bun run --filter './packages/*' build",
    "preview:dev": "bun run --filter '@drawspec/preview' dev",
    "docs:dev": "bun run --cwd apps/docs dev",
    "docs:build": "bun run --cwd apps/docs build",
    "changeset": "changeset",
    "release": "bun run check && changeset version && bun run build"
  },
  "devDependencies": {
    "@changesets/cli": "latest",
    "@drawspec/architecture": "workspace:*",
    "@drawspec/cli": "workspace:*",
    "@drawspec/core": "workspace:*",
    "@drawspec/docs": "workspace:*",
    "@drawspec/layout": "workspace:*",
    "@drawspec/renderer-svg": "workspace:*",
    "@drawspec/testkit": "workspace:*",
    "@drawspec/uml-component": "workspace:*",
    "@drawspec/uml-sequence": "workspace:*",
    "@drawspec/validation": "workspace:*",
    "@types/node": "25.9.1",
    "typescript": "latest"
  }
}
