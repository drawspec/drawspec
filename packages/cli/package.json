{
  "name": "@drawspec/cli",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "drawspec": "./dist/index.js",
    "ds": "./dist/index.js",
    "dspec": "./dist/index.js"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "bun": "./src/config.ts",
      "default": "./dist/config.js",
      "types": "./dist/config.d.ts"
    }
  },
  "dependencies": {
    "@drawspec/architecture": "workspace:*",
    "@drawspec/cache": "workspace:*",
    "@drawspec/core": "workspace:*",
    "@drawspec/docs": "workspace:*",
    "@drawspec/exporter-d2": "workspace:*",
    "@drawspec/exporter-mermaid": "workspace:*",
    "@drawspec/exporter-plantuml": "workspace:*",
    "@drawspec/layout": "workspace:*",
    "@drawspec/renderer-svg": "workspace:*",
    "@drawspec/uml-sequence": "workspace:*",
    "@drawspec/validation": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "latest"
  }
}
